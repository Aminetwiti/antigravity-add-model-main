{
  "name": "ag-doctor-ui",
  "version": "1.0.0",
  "description": "Antigravity Environment Doctor — Desktop UI",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "build:all": "electron-builder -mwl"
  },
  "author": "Aminetwiti",
  "license": "Apache-2.0",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.antigravity.ag-doctor",
    "productName": "Antigravity Doctor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "../ag-doctor/bin/**/*",
      "../ag-doctor/src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "../assets/icons/icon.png"
    },
    "portable": {
      "artifactName": "Antigravity-Doctor-${version}-portable.exe"
    }
  }
}
