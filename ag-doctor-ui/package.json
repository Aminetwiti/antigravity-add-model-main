{
  "name": "ag-doctor-ui",
  "version": "1.0.0",
  "description": "Premium Electron UI for the ag-doctor CLI",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/copy-assets.js && tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "npm run build && electron .",
    "dev": "tsc -p tsconfig.json --watch & electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "antigravity",
    "doctor",
    "electron",
    "cli",
    "diagnostic"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "dev.antigravity.doctor-ui",
    "productName": "ag-doctor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
